# ──────────────────────────────────────────────
# ROSE – environment configuration
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────

# ── LLM provider ────────────────────────────
# Supported: "openai", "alcf", "local" (Ollama / LM Studio / vLLM)
# If unset, ROSE reads the OPENAI_API_KEY environment variable directly.
LLM_PROVIDER=openai

# ── API key ─────────────────────────────────
# Generic key (works for any provider):
LLM_API_KEY=sk-...
# Or use the provider-specific variable instead:
# OPENAI_API_KEY=sk-...

# ── Model name ──────────────────────────────
# Default: gpt-4o
# For local models, use the model tag (e.g. llama3, mistral)
LLM_MODEL=gpt-4o

# ── Base URL (local / OpenAI-compatible only) ─
# Uncomment and set when using Ollama, LM Studio, vLLM, etc.
# LLM_BASE_URL=http://localhost:11434/v1

# ── Generation settings ─────────────────────
LLM_TEMPERATURE=0.0       # low temperature for deterministic YAML output
LLM_MAX_TOKENS=64000      # max output tokens per LLM call

# ── ALCF inference endpoints ────────────────
# Set LLM_PROVIDER=alcf to use Argonne Leadership Computing Facility models.
# Docs: https://docs.alcf.anl.gov/services/inference-endpoints/
# ALCF_CLUSTER=sophia         # "sophia" (vLLM) or "metis" (SambaNova)
# ALCF_ACCESS_TOKEN=...       # Globus token

# ── ROSE output settings ────────────────────
# Override default output directory
# ROSE_OUTPUT_DIR=results

# ── LangSmith tracing (optional) ────────────
# Enable LangChain tracing for debugging / monitoring.
# Requires: pip install langsmith
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_PROJECT=rose
